  <script>
    function openAIRecruiter() {
      alert(
        "Hi Rockstar! I am your AI Recruiter. Let me help you find your best career match at Daythree."
      );
    }

    function createSparkle() {
      const sparkle = document.createElement("div");

      const colorClass = Math.random() > 0.5 ? "purple" : "red";
      sparkle.classList.add("sparkle", colorClass);

      const randomX = Math.random() * window.innerWidth;
      const randomY = Math.random() * window.innerHeight;

      sparkle.style.left = randomX + "px";
      sparkle.style.top = randomY + "px";

      const randomSize = Math.random() * 8 + 6;
      sparkle.style.width = randomSize + "px";
      sparkle.style.height = randomSize + "px";

      document.body.appendChild(sparkle);

      setTimeout(() => {
        sparkle.remove();
      }, 3500);
    }

    function createSparkleBurst() {
      for (let i = 0; i < 6; i++) {
        setTimeout(createSparkle, i * 120);
      }
    }

    setInterval(createSparkleBurst, 1000);
  </script>
