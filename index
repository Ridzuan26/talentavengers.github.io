<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Infinity Careers Rockstar | Daythree</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: "Segoe UI", Arial, sans-serif;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      min-height: 100vh;
      color: #ffffff;
      overflow-x: hidden;
      background:
        linear-gradient(rgba(8, 6, 25, 0.72), rgba(8, 6, 25, 0.92)),
        url("uoa-business-park-shah-alam.jpg");
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background:
        radial-gradient(circle at 15% 20%, rgba(145, 65, 255, 0.25), transparent 28%),
        radial-gradient(circle at 85% 30%, rgba(255, 45, 85, 0.22), transparent 30%),
        linear-gradient(120deg, rgba(100, 0, 255, 0.13), rgba(255, 0, 80, 0.10));
      pointer-events: none;
      z-index: -1;
    }

    .navbar {
      width: 100%;
      padding: 22px 8%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: fixed;
      top: 0;
      z-index: 100;
      background: rgba(8, 6, 25, 0.76);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    }

    .logo {
      font-size: 24px;
      font-weight: 900;
      letter-spacing: 1px;
      color: #ffffff;
      text-transform: uppercase;
    }

    .logo span {
      color: #c052ff;
      text-shadow: 0 0 18px rgba(192, 82, 255, 0.8);
    }

    .navbar nav a {
      color: #ffffff;
      text-decoration: none;
      margin-left: 28px;
      font-size: 15px;
      font-weight: 600;
      transition: 0.3s;
    }

    .navbar nav a:hover {
      color: #ff416c;
    }

    .hero {
      min-height: 100vh;
      padding: 150px 8% 80px;
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      align-items: center;
      gap: 45px;
    }

    .hero-content h1 {
      font-size: clamp(42px, 6vw, 84px);
      line-height: 1;
      text-transform: uppercase;
      margin-bottom: 24px;
    }

    .hero-content h1 span {
      color: #c052ff;
      text-shadow:
        0 0 12px rgba(192, 82, 255, 0.9),
        0 0 32px rgba(255, 45, 85, 0.55);
    }

    .hero-content p {
      max-width: 720px;
      font-size: 18px;
      line-height: 1.75;
      color: #e8dcff;
      margin-bottom: 34px;
    }

    .hero-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
    }

    .btn {
      display: inline-block;
      padding: 15px 30px;
      border-radius: 40px;
      text-decoration: none;
      font-weight: 800;
      letter-spacing: 0.4px;
      transition: 0.3s;
      cursor: pointer;
      border: none;
    }

    .btn-primary {
      background: linear-gradient(135deg, #c052ff, #ff2d55);
      color: #ffffff;
      box-shadow: 0 0 28px rgba(192, 82, 255, 0.45);
    }

    .btn-secondary {
      background: rgba(255, 255, 255, 0.10);
      color: #ffffff;
      border: 1px solid rgba(255, 255, 255, 0.30);
    }

    .btn:hover {
      transform: translateY(-4px);
      box-shadow: 0 0 34px rgba(255, 45, 85, 0.45);
    }

    .hero-card {
      background: rgba(255, 255, 255, 0.09);
      border: 1px solid rgba(255, 255, 255, 0.20);
      backdrop-filter: blur(18px);
      border-radius: 30px;
      padding: 36px;
      box-shadow: 0 0 45px rgba(192, 82, 255, 0.24);
      position: relative;
      overflow: hidden;
    }

    .hero-card::before {
      content: "";
      position: absolute;
      width: 230px;
      height: 230px;
      background: rgba(255, 45, 85, 0.20);
      border-radius: 50%;
      top: -90px;
      right: -90px;
      filter: blur(12px);
    }

    .hero-card h3 {
      font-size: 27px;
      margin-bottom: 18px;
      color: #ff6f91;
      position: relative;
      z-index: 1;
    }

    .hero-card ul {
      list-style: none;
      position: relative;
      z-index: 1;
    }

    .hero-card li {
      padding: 14px 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.14);
      color: #f2eaff;
      line-height: 1.5;
    }

    .hero-card li::before {
      content: "✦";
      color: #c052ff;
      margin-right: 10px;
      text-shadow: 0 0 12px rgba(192, 82, 255, 0.9);
    }

    .pulse-ring {
      width: 175px;
      height: 175px;
      border: 2px solid rgba(192, 82, 255, 0.62);
      border-radius: 50%;
      margin: 35px auto 0;
      position: relative;
      animation: pulse 2.3s infinite;
      z-index: 1;
    }

    .pulse-ring::before {
      content: "∞";
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      font-size: 74px;
      color: #ffffff;
      text-shadow:
        0 0 18px rgba(192, 82, 255, 0.9),
        0 0 34px rgba(255, 45, 85, 0.75);
    }

    @keyframes pulse {
      0% {
        box-shadow: 0 0 0 0 rgba(192, 82, 255, 0.50);
      }

      70% {
        box-shadow: 0 0 0 30px rgba(192, 82, 255, 0);
      }

      100% {
        box-shadow: 0 0 0 0 rgba(192, 82, 255, 0);
      }
    }

    section {
      padding: 90px 8%;
    }

    .section-title {
      text-align: center;
      margin-bottom: 52px;
    }

    .section-title h2 {
      font-size: 38px;
      text-transform: uppercase;
      margin-bottom: 14px;
      color: #ffffff;
    }

    .section-title p {
      color: #e4d6ff;
      max-width: 730px;
      margin: auto;
      line-height: 1.75;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
    }

    .card {
      background: rgba(255, 255, 255, 0.09);
      border: 1px solid rgba(255, 255, 255, 0.17);
      border-radius: 26px;
      padding: 30px;
      backdrop-filter: blur(15px);
      transition: 0.3s;
      min-height: 225px;
    }

    .card:hover {
      transform: translateY(-8px);
      box-shadow:
        0 0 28px rgba(192, 82, 255, 0.28),
        0 0 42px rgba(255, 45, 85, 0.20);
      border-color: rgba(192, 82, 255, 0.65);
    }

    .card .icon {
      font-size: 38px;
      margin-bottom: 18px;
    }

    .card h3 {
      font-size: 22px;
      margin-bottom: 14px;
      color: #ff6f91;
    }

    .card p {
      color: #f1eaff;
      line-height: 1.65;
      font-size: 15px;
    }

    .vacancy {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .vacancy-tag {
      display: inline-block;
      width: fit-content;
      padding: 7px 15px;
      border-radius: 20px;
      background: rgba(192, 82, 255, 0.20);
      color: #e1b3ff;
      font-size: 13px;
      font-weight: 800;
      border: 1px solid rgba(192, 82, 255, 0.32);
    }

    .ai-section {
      text-align: center;
      background: linear-gradient(
        135deg,
        rgba(192, 82, 255, 0.16),
        rgba(255, 45, 85, 0.14)
      );
      border-top: 1px solid rgba(255, 255, 255, 0.13);
      border-bottom: 1px solid rgba(255, 255, 255, 0.13);
    }

    .ai-box {
      max-width: 820px;
      margin: auto;
      background: rgba(255, 255, 255, 0.10);
      border-radius: 32px;
      padding: 48px;
      border: 1px solid rgba(255, 255, 255, 0.22);
      backdrop-filter: blur(16px);
      box-shadow: 0 0 42px rgba(192, 82, 255, 0.20);
    }

    .ai-box h2 {
      font-size: 38px;
      margin-bottom: 18px;
      color: #ffffff;
      text-shadow: 0 0 18px rgba(255, 45, 85, 0.65);
    }

    .ai-box p {
      color: #f2eaff;
      line-height: 1.75;
      margin-bottom: 30px;
    }

    footer {
      padding: 36px 8%;
      text-align: center;
      color: #d8c9ef;
      background: rgba(5, 4, 20, 0.88);
      border-top: 1px solid rgba(255, 255, 255, 0.12);
    }

    .sparkle {
      position: fixed;
      width: 9px;
      height: 9px;
      border-radius: 50%;
      z-index: 20;
      pointer-events: none;
      animation: sparkleMove 3.5s ease-out forwards;
    }

    .sparkle.purple {
      background: #c052ff;
      box-shadow:
        0 0 8px #c052ff,
        0 0 18px #c052ff,
        0 0 34px rgba(192, 82, 255, 0.85);
    }

    .sparkle.red {
      background: #ff2d55;
      box-shadow:
        0 0 8px #ff2d55,
        0 0 18px #ff2d55,
        0 0 34px rgba(255, 45, 85, 0.85);
    }

    .sparkle::before,
    .sparkle::after {
      content: "";
      position: absolute;
      background: inherit;
      box-shadow: inherit;
      border-radius: 20px;
    }

    .sparkle::before {
      width: 2px;
      height: 24px;
      left: 3.5px;
      top: -7px;
    }

    .sparkle::after {
      width: 24px;
      height: 2px;
      left: -7px;
      top: 3.5px;
    }

    @keyframes sparkleMove {
      0% {
        opacity: 0;
        transform: scale(0.35) translateY(0) rotate(0deg);
      }

      15% {
        opacity: 1;
      }

      70% {
        opacity: 1;
      }

      100% {
        opacity: 0;
        transform: scale(1.5) translateY(-130px) rotate(180deg);
      }
    }

    @media (max-width: 900px) {
      .hero {
        grid-template-columns: 1fr;
        padding-top: 145px;
      }

      .grid {
        grid-template-columns: 1fr;
      }

      .navbar {
        flex-direction: column;
        gap: 15px;
        padding: 18px 6%;
      }

      .navbar nav {
        text-align: center;
      }

      .navbar nav a {
        margin: 0 9px;
        font-size: 14px;
      }

      .hero-card,
      .ai-box {
        padding: 30px;
      }
    }
  </style>
</head>

